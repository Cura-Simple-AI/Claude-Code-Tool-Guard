# ─── argparse setup ───────────────────────────────────────────────────


def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="tg",
        description="tool-guard management CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--version", action="version", version=f"tool-guard {VERSION}")
    sp = p.add_subparsers(dest="cmd", metavar="<command>")

    sp_list = sp.add_parser("list", help="list installed tool-guards")
    sp_list.set_defaults(func=cmd_list)

    sp_status = sp.add_parser("status", help="show install + config + log status")
    sp_status.add_argument("tool", nargs="?", help="(optional) restrict to one tool")
    sp_status.set_defaults(func=cmd_status)

    sp_check = sp.add_parser("check", help="dry-run classify a command")
    sp_check.add_argument("tool", help="tool-guard name (e.g. az, git)")
    sp_check.add_argument("args", nargs=argparse.REMAINDER, help="argv to classify")
    sp_check.set_defaults(func=cmd_check)

    sp_install = sp.add_parser("install", help="install engine + named tool-guards")
    sp_install.add_argument("names", nargs="*", help="tool-guard to install (default: all)")
    sp_install.set_defaults(func=cmd_install)

    sp_uninstall = sp.add_parser("uninstall", help="uninstall named tool-guards + engine")
    sp_uninstall.add_argument("names", nargs="*", help="tool-guard to remove (default: all)")
    sp_uninstall.set_defaults(func=cmd_uninstall)

    sp_log = sp.add_parser("log", help="show last N log entries")
    sp_log.add_argument("tool", help="tool-guard name")
    sp_log.add_argument("-n", type=int, default=10, help="number of entries (default 10)")
    sp_log.set_defaults(func=cmd_log)

    sp_cfg = sp.add_parser("config", help="config inspection + maintenance")
    sp_cfg_sub = sp_cfg.add_subparsers(dest="cfg_cmd", metavar="<subcommand>")

    sp_cfg_show = sp_cfg_sub.add_parser("show", help="print merged effective config")
    sp_cfg_show.add_argument("tool", help="tool-guard name")
    sp_cfg_show.set_defaults(func=cmd_config_show)

    sp_cfg_init = sp_cfg_sub.add_parser("init", help="initialize from example template")
    sp_cfg_init.add_argument("tool", help="tool-guard name")
    sp_cfg_init.add_argument("--force", action="store_true", help="overwrite if exists")
    sp_cfg_init.set_defaults(func=cmd_config_init)

    sp_cfg_edit = sp_cfg_sub.add_parser("edit", help="open config in $EDITOR")
    sp_cfg_edit.add_argument("tool", help="tool-guard name")
    sp_cfg_edit.add_argument("--local", action="store_true",
                             help="edit the per-user .local.json file (gitignored)")
    sp_cfg_edit.set_defaults(func=cmd_config_edit)

    sp_cfg_validate = sp_cfg_sub.add_parser("validate", help="validate JSON + schema")
    sp_cfg_validate.add_argument("tool", nargs="?", help="(optional) restrict to one tool")
    sp_cfg_validate.set_defaults(func=cmd_config_validate)

    sp_add = sp.add_parser("add", help="scaffold a new tool-guard")
    sp_add.add_argument("tool", help="new tool-guard name (e.g. gh)")
    sp_add.set_defaults(func=cmd_add)

    sp_test = sp.add_parser("test", help="run all test suites")
    sp_test.set_defaults(func=cmd_test)

    sp_version = sp.add_parser("version", help="show version info")
    sp_version.set_defaults(func=cmd_version)

    sp_help = sp.add_parser("help", help="show help (optionally for a specific command)")
    sp_help.add_argument("command", nargs="?", help="command to detail")
    sp_help.set_defaults(func=cmd_help)

    return p


SUBPARSERS = None  # populated at parse time, used by cmd_help


def main() -> int:
    global SUBPARSERS
    parser = _build_parser()
    SUBPARSERS = parser._subparsers._group_actions[0]  # type: ignore  # for cmd_help

    args = parser.parse_args()
    if not args.cmd:
        parser.print_help()
        return 0
    if args.cmd == "config" and not getattr(args, "cfg_cmd", None):
        parser.parse_args(["config", "--help"])
        return 1
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
