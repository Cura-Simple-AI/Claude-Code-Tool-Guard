}


def cmd_add(args) -> int:
    """Scaffold a new tool-guard: <tool>/wrapper.py + example config."""
    if _is_installed_mode():
        print(_red("tg add: needs to write into the source tree (PKG_ROOT/<tool>/wrapper.py + "
                   "examples/.tool-guard/), but we're running from /usr/local/bin/. "
                   "Run from a source clone (e.g. ~/.local/share/tool-guard-source/)."),
              file=sys.stderr)
        return 1

    name = args.tool
    if not name or not name.replace("-", "").isalnum():
        print(_red(f"tg: invalid tool name '{name}' — use only alphanumerics + dashes"), file=sys.stderr)
        return 1
    if name.startswith("-") or name.endswith("-"):
        print(_red(f"tg: tool name '{name}' must not start or end with a dash"), file=sys.stderr)
        return 1
    if name in _RESERVED_NAMES:
        print(
            _red(f"tg: '{name}' is reserved (collides with package layout)"),
            file=sys.stderr,
        )
        print(f"     Reserved: {', '.join(sorted(_RESERVED_NAMES))}", file=sys.stderr)
        return 1

    target_dir = PKG_ROOT / name
    if target_dir.exists():
        print(_red(f"tg: {target_dir} already exists. Edit the existing tool-guard or remove it first."), file=sys.stderr)
        return 1

    target_dir.mkdir()
    upper = name.upper().replace("-", "_")

    # Stub template MUST stay in sync with the production stubs at
    # az/wrapper.py, gh/wrapper.py, git/wrapper.py. The TOOL_GUARD_STUB_v1
    # marker is required for detection; the TG_REAL_BIN_DEFAULT marker
    # is required for `tg install`'s REAL_BIN patching. Drift between
    # this template and production stubs is a P1 bug (architecture
    # review finding) — there's a test in _tests/tg.test.sh that
    # asserts they match. If you change this template, update the
    # production stubs and the test in lockstep.
    stub = f'''#!/usr/bin/env python3
"""{name} tool-guard — thin stub that delegates to the shared tool_guard engine.

All policy enforcement lives in scripts/tool-guard/tool_guard.py.
See ../README.md for the system architecture and ./POLICY.md for
{name}-specific policy notes (you may want to write that file).
"""
# TOOL_GUARD_STUB_v1 — canonical magic line. See az/wrapper.py header.
import os
import sys

TOOL = "{name}"
REAL = os.environ.get("{upper}_TG_REAL_BIN", "/usr/bin/{name}")  # TG_REAL_BIN_DEFAULT

# TOOL_GUARD_ENGINE_DIR honored only in test mode (TG_TEST_MODE=1 +
# /etc/tool-guard/test-mode-enabled file). See SECURITY.md.
_test_mode = (os.environ.get("TG_TEST_MODE") == "1"
              and os.path.isfile("/etc/tool-guard/test-mode-enabled"))
_engine_dirs = ([os.environ["TOOL_GUARD_ENGINE_DIR"]]
                if (_test_mode and os.environ.get("TOOL_GUARD_ENGINE_DIR"))
                else ["/usr/local/lib/tool-guard",
                      os.path.dirname(os.path.dirname(os.path.abspath(__file__)))])
for _cand in _engine_dirs:
    if os.path.exists(os.path.join(_cand, "tool_guard.py")):
        sys.path.insert(0, _cand)
        break

try:
    from tool_guard import run  # noqa: E402
except ImportError as e:
    # Fail-fast on missing engine. Falling through to the real binary
    # would silently disable policy enforcement.
    sys.stderr.write(
        f"{{TOOL}}-tool-guard: ❌ tool_guard engine not found ({{e}}).\\n"
        "  Expected at /usr/local/lib/tool-guard/tool_guard.py (installed)\\n"
        "  or alongside this file (dev/test).\\n"
        "  Run scripts/tool-guard/install.sh to (re)install.\\n"
        f"  To bypass the guard for this call only: {{REAL}} <args>\\n"
    )
    sys.exit(127)

sys.exit(run(
    tool_name=TOOL,
    real_bin=REAL,
    secret_flags=frozenset(),  # add per-tool secret flags here, e.g. {{"--token", "--password"}}
))
'''
    stub_path = target_dir / "wrapper.py"
    stub_path.write_text(stub)
    stub_path.chmod(0o755)

    policy = f'''# {name}-tool-guard policy — design notes

The `.tool-guard/{name}.config.json` file controls what `{name}`
invocations the tool-guard at `/usr/local/bin/{name}` allows or blocks.

## Categories

| Category | Effect |
|----------|--------|
| `allow` | Log + exec real binary. |
| `warn`  | Stderr advisory + log + exec. |
| `deny`  | Log + stderr error + exit 13. Real binary not called. |

## Precedence

`deny > warn > allow > defaultMode`. First match within each category
wins.

## How to test

```bash
{upper}_TG_DRYRUN=1 {name} <some-command>
# → DRYRUN: classify=...
```

Or use `tg`:

```bash
tg check {name} <some-command>
```

## TODO

- [ ] Document the safety rationale for each `deny` rule below
- [ ] Add Newman / Postman / smoke tests for representative invocations
'''
    (target_dir / "POLICY.md").write_text(policy)

    examples_dir = PKG_ROOT / "examples" / ".tool-guard"
    examples_dir.mkdir(parents=True, exist_ok=True)
    example_config = {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "_comment": (
            f"Starter policy for {name}. defaultMode='prompt' means an unmatched "
            "call triggers an interactive prompt (TTY) or auto-deny (non-TTY). "
            "Edit allow/warn/deny lists to match your team's needs. See "
            f"../{name}/POLICY.md."
        ),
        "defaultMode": "prompt",
        "allow": [
            "version",
            "--version",
            "--help",
            "-h",
        ],
        "warn": [],
        "deny": [],
    }
    example_path = examples_dir / f"{name}.config.json"
    example_path.write_text(json.dumps(example_config, indent=2) + "\n")

    print(_green(f"✓ Created scaffold for new tool-guard '{name}'"))
    print(f"  stub:    {stub_path}")
    print(f"  policy:  {target_dir / 'POLICY.md'}")
    print(f"  config:  {example_path}")
    print()
    print("Next steps:")
    print(f"  1. Edit {example_path} — add allow/warn/deny rules for {name}")
    print(f"  2. Copy to your repo: cp {example_path} <repo>/.tool-guard/")
    print(f"  3. Add a smoke test at _tests/{name}.smoke.test.sh (template: az.smoke.test.sh)")
    print(f"  4. Run: tg install {name}")
    return 0


def cmd_test(_args) -> int:
    """Run all test suites under _tests/. When tg is installed (running
    from /usr/local/bin/), the _tests/ dir isn't co-located — point the
    user at the source clone instead of failing opaquely."""
    tests_dir = PKG_ROOT / "_tests"
    if not tests_dir.is_dir():
        # Likely running from /usr/local/bin/ (installed mode), where
        # _tests/ doesn't ship. Point at the source clone if known.
        if _is_installed_mode():
            cache_hint = os.path.expanduser("~/.local/share/tool-guard-source")
            print(
                _yellow(
                    f"tg: tests don't ship with the installed package. To run\n"
                    f"     them, cd into a source clone of the repo and run\n"
                    f"     `bash _tests/<suite>.test.sh` or `tg test` from there.\n"
                    f"     Common cache (if installed via tool-guard-install.sh):\n"
                    f"       cd {cache_hint} && tg test"
                ),
                file=sys.stderr,
            )
        else:
            print(_red(f"tg: no _tests/ directory at {tests_dir}"), file=sys.stderr)
        return 1
    suites = sorted(tests_dir.glob("*.test.sh"))
    if not suites:
        print(_red(f"tg: no test suites found in {tests_dir}"), file=sys.stderr)
        return 1
    failed = 0
    for s in suites:
        print(_bold(f"\n── {s.name} ──"))
        ec = subprocess.run(["bash", str(s)]).returncode
        if ec != 0:
            failed += 1
            print(_red(f"  → FAILED (exit {ec})"))
    print()
    if failed:
        print(_red(f"{failed}/{len(suites)} suite(s) failed"))
        return 1
    print(_green(f"All {len(suites)} suites passed"))
    return 0


