#!/usr/bin/env python3
"""tg — tool-guard management CLI.

Convenience commands for the tool-guard policy system. Wraps the
existing install.sh / uninstall.sh + adds inspection, dry-run, log
viewing, config printing, and new-tool-guard scaffolding. No external
dependencies — pure stdlib.

Usage:
  tg <command> [args...]

Commands:
  list                    list installed tool-guards + the engine
  status [tool]           show install + config + log status (all tools, or one)
  check <tool> <args...>  dry-run classify a command (no exec)
  install [name...]       install engine + named tool-guards (delegates to install.sh)
  uninstall [name...]     uninstall named tool-guards + engine (delegates to uninstall.sh)
  log <tool> [-n N]       show last N log entries (default 10)
  config show <tool>      print the merged effective config for a tool
  add <tool>              scaffold a new tool-guard (stub + example config)
  test                    run all test suites
  version                 show tool-guard version
  help [command]          show help (this text, or detail for one command)

Examples:
  tg status
  tg check az group delete --name foo
  tg log az -n 20
  tg add gh
  tg config show git

The CLI installs to /usr/local/bin/tg via install.sh — see EXTRACT.md
and README.md for the broader install/extract story.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

VERSION = "0.1.0"

# Paths can be overridden via env vars — useful for tests and for
# users who customised install.sh / uninstall.sh to a different prefix.
INSTALL_DIR = Path(os.environ.get("TG_INSTALL_DIR", "/usr/local/bin"))
ENGINE_DIR = Path(os.environ.get("TG_ENGINE_DIR", "/usr/local/lib/tool-guard"))
LOG_DIR_BASE = Path(os.environ.get("TG_LOG_DIR", "/tmp/tool-guard"))

# Resolve PKG_ROOT relative to this script's location. Works both inside
# the parent repo (scripts/tool-guard/) and post-extract (extracted root).
_HERE = Path(__file__).resolve().parent
PKG_ROOT = _HERE


def _color_supported() -> bool:
    return sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(text: str, code: str) -> str:
    if not _color_supported():
        return text
    return f"\033[{code}m{text}\033[0m"


def _green(s: str) -> str:  return _c(s, "32")
def _red(s: str) -> str:    return _c(s, "31")
def _yellow(s: str) -> str: return _c(s, "33")
def _bold(s: str) -> str:   return _c(s, "1")
def _dim(s: str) -> str:    return _c(s, "2")


# ─── Discovery ────────────────────────────────────────────────────────


def _is_installed_mode() -> bool:
    """True when running from the installed location (/usr/local/bin/tg).
    In installed mode there are no <name>/wrapper.py subdirs next to tg —
    the wrappers are flat files at INSTALL_DIR/<name>."""
    return PKG_ROOT == INSTALL_DIR


# Test-mode gate — mirrors tool_guard.py. TG_INSTALL_DIR / TG_ENGINE_DIR
# / TG_LOG_DIR remain ungated; they don't affect policy decisions.
TG_TEST_MODE_FILE = "/etc/tool-guard/test-mode-enabled"


def _test_mode_active() -> bool:
    return (os.environ.get("TG_TEST_MODE") == "1"
            and os.path.isfile(TG_TEST_MODE_FILE))


def _source_root() -> Path | None:
    """Locate a directory that holds the source layout (<name>/wrapper.py
    subdirs, _tests/, examples/). In source-tree mode that's PKG_ROOT
    itself. In installed mode, fall back to the cache the
    tool-guard-install.sh script populates (~/.local/share/tool-guard-source/,
    overridable via TOOL_GUARD_CACHE_DIR). Returns None if neither
    location has the expected layout."""
    candidates: list[Path] = []
    if not _is_installed_mode():
        candidates.append(PKG_ROOT)
    cache = Path(os.environ.get("TOOL_GUARD_CACHE_DIR")
                 or os.path.expanduser("~/.local/share/tool-guard-source"))
    candidates.append(cache)
    for c in candidates:
        if (c / "tool_guard.py").is_file():
            return c
    return None


def _discover_guards() -> list[str]:
    """List tool-guards. In source-tree mode: subdirs of PKG_ROOT containing
    a wrapper.py (skips _-prefixed dirs and examples/). In installed mode:
    flat files at INSTALL_DIR that pass _guard_installed() (i.e. are OUR
    wrappers, not unrelated /usr/local/bin/ binaries)."""
    if _is_installed_mode():
        names = []
        for p in sorted(INSTALL_DIR.iterdir()):
            if not p.is_file():
                continue
            if p.name == "tg":
                continue
            if _guard_installed(p.name):
                names.append(p.name)
        return names
    names = []
    for d in sorted(PKG_ROOT.iterdir()):
        if not d.is_dir() or d.name.startswith("_") or d.name.startswith("."):
            continue
        if d.name in ("examples",):
            continue
        if (d / "wrapper.py").is_file():
            names.append(d.name)
    return names


def _walk_up_for_guards_dir(start: Path | None = None) -> Path | None:
    """Walk-up search ONLY — no home fallbacks. Use for write operations
    (init / edit) where the user expects the file to land in their cwd
    tree, not somewhere unrelated like ~/.config/."""
    p = (start or Path.cwd()).resolve()
    for _ in range(20):
        c = p / ".tool-guard"
        if c.is_dir():
            return c
        if p == p.parent:
            return None
        p = p.parent
    return None


def _find_guards_dir(start: Path | None = None) -> Path | None:
    """Locate the .tool-guard/ config dir. Mirrors the engine:
      1. $TOOL_GUARD_DIR override (test-mode-gated, see engine docstring)
      2. cwd walk-up
      3. ~/.config/tool-guard/
      4. ~/.tool-guard/

    For READ operations (status, log, check, config show). Write
    operations should use _walk_up_for_guards_dir() instead."""
    explicit = os.environ.get("TOOL_GUARD_DIR")
    if explicit and _test_mode_active():
        p = Path(explicit)
        return p if p.is_dir() else None
    walked = _walk_up_for_guards_dir(start)
    if walked is not None:
        return walked
    home = Path.home()
    for fallback in (home / ".config" / "tool-guard", home / ".tool-guard"):
        if fallback.is_dir():
            return fallback
    return None


def _engine_installed() -> Path | None:
    p = ENGINE_DIR / "tool_guard.py"
    return p if p.is_file() else None


# Canonical markers in every stub. Detection is structural, not
# heuristic: STUB_MAGIC_LINE identifies our stubs; REAL_BIN_MARKER
# locates the assignment _patch_real_bin replaces.
STUB_MAGIC_LINE = b"TOOL_GUARD_STUB_v1"
REAL_BIN_MARKER = "# TG_REAL_BIN_DEFAULT"


def _file_is_our_stub(head: bytes) -> bool:
    """Inspect the first ~2 KB of a file and decide whether it's one of
    our tool-guard stubs. Single source of truth for both
    _guard_installed (post-install detection) and _is_our_wrapper
    (install-time conflict detection — refuse to overwrite non-stubs).

    Match priority:
      1. STUB_MAGIC_LINE present → definitely ours (current generation).
      2. Python shebang + 'tool_guard' string → legacy stubs without
         the magic line (back-compat for stubs that pre-date this marker).
    """
    if not head.startswith(b"#!") or b"python" not in head.split(b"\n", 1)[0]:
        return False
    if STUB_MAGIC_LINE in head:
        return True
    # Legacy fallback: pre-marker stubs reference 'tool_guard' (the
    # engine module). Drop this branch once all installed stubs have
    # been regenerated with the marker.
    return b"tool_guard" in head


def _guard_installed(name: str) -> Path | None:
    """Return path if /usr/local/bin/<name> is OUR tool-guard. Returns
    None if the binary is missing OR if it's something else (e.g. the
    real /usr/bin/git copied to /usr/local/bin/git by accident)."""
    p = INSTALL_DIR / name
    if not (p.is_file() and os.access(p, os.X_OK)):
        return None
    try:
        with p.open("rb") as f:
            head = f.read(2048)
    except OSError:
        return None
    return p if _file_is_our_stub(head) else None


def _log_file(name: str) -> Path | None:
    """Most recent log file for a tool-guard, or None.

    Layout: /tmp/tool-guard/<name>_YYYYMMDD.log (flat dir, one file per
    tool per day). Sorted lexicographically picks the latest date."""
    if not LOG_DIR_BASE.is_dir():
        return None
    files = sorted(LOG_DIR_BASE.glob(f"{name}_*.log"))
    return files[-1] if files else None


# ─── Commands ─────────────────────────────────────────────────────────


def cmd_list(_args) -> int:
    """List discoverable tool-guards + their installed status."""
    if _is_installed_mode():
        header = f"{_bold('Installed tool-guards')} ({INSTALL_DIR}):"
    else:
        header = f"{_bold('Tool-guards in package')} ({PKG_ROOT}):"
    print(header)
    guards = _discover_guards()
    if not guards:
        print(_dim("  (none discovered)"))
    for name in guards:
        installed = _guard_installed(name)
        marker = _green("✓ installed") if installed else _dim("not installed")
        print(f"  {name:<10} {marker}" + (f" ({installed})" if installed else ""))
    print()
    engine = _engine_installed()
    if engine:
        print(f"{_bold('Engine')}: {_green('✓ installed')} ({engine})")
    else:
        print(f"{_bold('Engine')}: {_dim('not installed')} (run `tg install`)")
    return 0


def cmd_status(args) -> int:
    """Show install + config + log status. Optionally filter to one tool."""
    target = args.tool
    guards = [target] if target else _discover_guards()

    cwd_dir = _find_guards_dir()
    if cwd_dir:
        print(f"{_bold('Config dir')} ({_dim('walked up from cwd')}): {cwd_dir}")
    else:
        print(f"{_bold('Config dir')}: {_red('not found')} ({_dim('no .tool-guard/ in any ancestor of cwd')})")
    print()

    src = _source_root()
    for name in guards:
        # In source mode, "in package" means there's a wrapper.py beside us.
        # In installed mode, the source isn't required to be present —
        # what matters is whether the binary at INSTALL_DIR/<name> is ours.
        installed = _guard_installed(name)
        in_package = ((src and (src / name / "wrapper.py").is_file())
                      or installed is not None)
        if not in_package:
            print(f"{_yellow('?')} {name}: not in package")
            continue

        if installed:
            print(f"{_green('●')} {_bold(name):<24} installed at {installed}")
        else:
            print(f"{_dim('○')} {_bold(name):<24} not installed")

        # Config files (per-tool)
        if cwd_dir:
            shared = cwd_dir / f"{name}.config.json"
            local = cwd_dir / f"{name}.config.local.json"
            print(f"    shared cfg:   {_green('✓') if shared.exists() else _dim('—')} {shared}")
            print(f"    local cfg:    {_green('✓') if local.exists() else _dim('—')} {local}")
        # Log
        log = _log_file(name)
        if log:
            try:
                count = sum(1 for _ in log.open())
                print(f"    log:          {_green('✓')} {log} ({count} entries)")
            except OSError:
                print(f"    log:          {_yellow('?')} {log}")
        else:
            print(f"    log:          {_dim('—')} {LOG_DIR_BASE}/{name}_*.log (no entries yet)")
        print()

    return 0


def cmd_check(args) -> int:
    """Dry-run classify a command. Pretty-formatted output explaining the
    decision + matched rule + custom message (if any) + what would happen
    if you ran the command for real."""
    tool = args.tool
    extra = args.args
    # In installed mode the source wrapper.py is in the cache, not next
    # to the installed binary — fall back to _source_root() so check
    # works post-install too. As a last resort, invoke the installed
    # wrapper directly (it will still respond to <TOOL>_TG_DRYRUN).
    src = _source_root()
    wrapper_path = (src / tool / "wrapper.py") if src else None
    if wrapper_path is None or not wrapper_path.is_file():
        installed = _guard_installed(tool)
        if installed:
            wrapper_path = installed
        else:
            print(_red(f"tg: no tool-guard for tool '{tool}'"), file=sys.stderr)
            print(f"     Looked at: {src / tool / 'wrapper.py' if src else '(no source root)'} and {INSTALL_DIR / tool}", file=sys.stderr)
            print(f"     Available: {', '.join(_discover_guards()) or '(none)'}", file=sys.stderr)
            return 1

    cmd_repr = f"{tool} {' '.join(extra)}"
    print(f"{_bold('Checking:')} {cmd_repr}")
    print()

    # Run the tool-guard in dry-run mode and capture stderr (where DRYRUN line
    # is printed). Use the engine's classify directly for richer info
    # (matched rule, custom message), but fall back to the dry-run line
    # if engine isn't importable.
    env_prefix = tool.upper().replace("-", "_")
    env = os.environ.copy()
    env[f"{env_prefix}_TG_DRYRUN"] = "1"
    env.setdefault(f"{env_prefix}_TG_REAL_BIN", "/bin/true")
    proc = subprocess.run(
        [sys.executable, str(wrapper_path), *extra],
        env=env, capture_output=True, text=True,
    )
    # Find the DRYRUN line specifically — not just the first stderr
    # line. Other warnings (REAL_BIN basename mismatch, missing engine,
    # etc.) may appear before the actual classification result.
    all_output = (proc.stderr or "") + (proc.stdout or "")
    line = ""
    for cand in all_output.splitlines():
        if "DRYRUN:" in cand and "classify=" in cand:
            line = cand
            break
    if not line and all_output:
        # Fallback: use first non-empty line (preserves old behavior
        # for unexpected wrapper outputs).
        for cand in all_output.splitlines():
            if cand.strip():
                line = cand
                break

    # Parse the DRYRUN line: "DRYRUN: classify=X rule=Y under_claude=Z — outcome"
    decision = _extract(line, "classify=")
    rule = _extract(line, "rule=")
    under_claude = _extract(line, "under_claude=")

    # Render decision with color + icon
    icons = {"allow": ("✅", _green), "warn": ("⚠ ", _yellow),
             "deny": ("❌", _red), "prompt": ("❓", _yellow)}
    icon, color = icons.get(decision, ("?", _bold))
    decision_label = {
        "allow":  "ALLOWED",
        "warn":   "ALLOWED with WARNING",
        "deny":   "DENIED",
        "prompt": "WOULD PROMPT (TTY) or AUTO-DENY (non-TTY)",
    }.get(decision, decision.upper() if decision else "UNKNOWN")

    print(f"  {icon} {color(_bold(decision_label))}")
    print(f"     rule:         {rule or _dim('(no rule — defaultMode)')}")
    print(f"     under Claude: {under_claude or _dim('(unknown)')}")

    # If the rule matched, fetch its message from the engine for richer output
    msg = _fetch_rule_message(tool, rule)
    if msg:
        print(f"     message:      ", end="")
        for i, line in enumerate(msg.splitlines()):
            print(("" if i == 0 else "                  ") + line)

    # Tell the user what would happen on a real (non-dryrun) invocation
    print()
    if decision == "deny":
        print(f"  {_dim('Would exit with code 13.')}")
        print(f"  {_dim(f'  To allow: edit .tool-guard/{tool}.config.json')}")
    elif decision == "warn":
        print(f"  {_dim('Would print warning to stderr + execute the real binary.')}")
    elif decision == "allow":
        print(f"  {_dim('Would log + execute the real binary.')}")
    elif decision == "prompt":
        print(f"  {_dim('Interactive shell: prompts [a/A/d/D]. Non-TTY (CI, scripts): auto-deny.')}")

    return 0


def _extract(line: str, key: str) -> str:
    """Extract value of `key=value` from a string. Handles quoted values like rule="foo*"."""
    idx = line.find(key)
    if idx < 0:
        return ""
    rest = line[idx + len(key):]
    if rest.startswith('"'):
        end = rest.find('"', 1)
        return rest[1:end] if end > 0 else rest[1:]
    return rest.split(" ", 1)[0].rstrip(",")


def cmd_config_edit(args) -> int:
    """Open the shared (or local) config file in $EDITOR. Creates it
    from the example template if it doesn't exist yet. Anchors at
    cwd (walk-up only) — edit is a write-or-create operation."""
    cwd_dir = _walk_up_for_guards_dir()
    if cwd_dir is None:
        # Create .tool-guard/ at cwd as a starting point
        cwd_dir = Path.cwd() / ".tool-guard"
        try:
            cwd_dir.mkdir(parents=True, exist_ok=True)
        except OSError as e:
            print(_red(f"tg: cannot create {cwd_dir}: {e}"), file=sys.stderr)
            return 1
        print(_dim(f"  (created {cwd_dir})"))

    suffix = ".local.json" if args.local else ".json"
    target = cwd_dir / f"{args.tool}.config{suffix}"
    if not target.exists():
        # Copy from example if available, else create empty
        example = PKG_ROOT / "examples" / ".tool-guard" / f"{args.tool}.config.json"
        if example.exists() and not args.local:
            shutil.copy(example, target)
            print(_green(f"  ✓ Copied template from {example}"))
        else:
            stub = {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "_comment": (
                    f"Per-{'user' if args.local else 'team'} {args.tool}-tool-guard policy."
                    + (" Gitignored." if args.local else "")
                ),
                "defaultMode": "prompt",
                "allow": [],
                "warn": [],
                "deny": [],
            }
            target.write_text(json.dumps(stub, indent=2) + "\n")
            print(_green(f"  ✓ Created empty config"))
        print(f"  {target}")

    editor = os.environ.get("EDITOR") or os.environ.get("VISUAL") or "vi"
    print(_dim(f"  Opening {target} in $EDITOR ({editor})..."))
    return subprocess.run([editor, str(target)]).returncode


def cmd_config_init(args) -> int:
    """Initialize .tool-guard/<tool>.config.json from the example template.
    Anchors at cwd (walk-up only, no home fallbacks) — init is a write
    operation that should land where the user is, not at ~/.config/."""
    cwd_dir = _walk_up_for_guards_dir()
    if cwd_dir is None:
        cwd_dir = Path.cwd() / ".tool-guard"
        cwd_dir.mkdir(parents=True, exist_ok=True)
        print(_dim(f"  Created {cwd_dir}"))

    target = cwd_dir / f"{args.tool}.config.json"
    if target.exists() and not args.force:
        print(_red(f"tg: {target} already exists. Use --force to overwrite."), file=sys.stderr)
        return 1

    example = PKG_ROOT / "examples" / ".tool-guard" / f"{args.tool}.config.json"
    if not example.exists():
        print(_red(f"tg: no example template for '{args.tool}' at {example}"), file=sys.stderr)
        print(f"     Available: {', '.join(sorted(p.stem.replace('.config','') for p in (PKG_ROOT / 'examples' / '.tool-guard').glob('*.json') if not p.name.startswith('_')))}", file=sys.stderr)
        return 1

    shutil.copy(example, target)
    print(_green(f"✓ Initialized {target}"))
    print(_dim(f"  (copied from {example})"))
    print()
    print("Also consider initializing _defaults.json (cross-cutting rules):")
    defaults_target = cwd_dir / "_defaults.json"
    defaults_example = PKG_ROOT / "examples" / ".tool-guard" / "_defaults.json"
    if not defaults_target.exists() and defaults_example.exists():
        print(f"  cp {defaults_example} {defaults_target}")
    elif defaults_target.exists():
        print(_dim(f"  (already exists at {defaults_target})"))

    return 0


def cmd_config_validate(args) -> int:
    """Validate one or all tool-guards' config files. Reports JSON syntax errors,
    schema issues, and unknown defaultMode values."""
    cwd_dir = _find_guards_dir()
    if cwd_dir is None:
        print(_red(f"tg: no .tool-guard/ found from cwd"), file=sys.stderr)
        return 1

    if args.tool:
        files = [
            cwd_dir / f"{args.tool}.config.json",
            cwd_dir / f"{args.tool}.config.local.json",
        ]
    else:
        files = sorted(cwd_dir.glob("*.json"))

    files = [f for f in files if f.exists()]
    if not files:
        print(_dim(f"  (no config files found in {cwd_dir})"))
        return 0

    all_ok = True
    for f in files:
        issues = _validate_config_file(f)
        if not issues:
            print(f"  {_green('✓')} {f.name}")
        else:
            all_ok = False
            print(f"  {_red('✗')} {f.name}:")
            for issue in issues:
                print(f"      {_red('•')} {issue}")
    return 0 if all_ok else 1


def _validate_config_file(path: Path) -> list[str]:
    """Return a list of issue strings; empty if config is valid."""
    issues = []
    try:
        with path.open() as f:
            data = json.load(f)
    except json.JSONDecodeError as e:
        return [f"invalid JSON: {e}"]
    except OSError as e:
        return [f"cannot read: {e}"]
    if not isinstance(data, dict):
        return [f"top-level must be an object, got {type(data).__name__}"]

    valid_modes = {"deny", "allow", "warn", "prompt"}
    is_defaults = path.name == "_defaults.json"

    # defaultMode (per-tool only; defaults file shouldn't have it)
    if "defaultMode" in data:
        if is_defaults:
            issues.append("_defaults.json should NOT have 'defaultMode' (it's per-tool)")
        elif data["defaultMode"] not in valid_modes:
            issues.append(
                f"defaultMode={data['defaultMode']!r} invalid — must be one of {sorted(valid_modes)}"
            )

    # allow/warn/deny lists
    for category in ("allow", "warn", "deny"):
        if category not in data:
            continue
        rules = data[category]
        if not isinstance(rules, list):
            issues.append(f"'{category}' must be an array, got {type(rules).__name__}")
            continue
        for i, rule in enumerate(rules):
            if isinstance(rule, str):
                continue  # plain pattern, OK
            if not isinstance(rule, dict):
                issues.append(f"'{category}'[{i}] must be a string or object, got {type(rule).__name__}")
                continue
            if "pattern" not in rule:
                issues.append(f"'{category}'[{i}] missing required 'pattern' field")
                continue
            if not isinstance(rule["pattern"], str):
                issues.append(
                    f"'{category}'[{i}].pattern must be a string, got {type(rule['pattern']).__name__}"
                )
            if "claude_only" in rule and not isinstance(rule["claude_only"], bool):
                issues.append(
                    f"'{category}'[{i}].claude_only must be true/false, got {type(rule['claude_only']).__name__}"
                )
            if "message" in rule and not isinstance(rule["message"], str):
                issues.append(
                    f"'{category}'[{i}].message must be a string, got {type(rule['message']).__name__}"
                )
            # type field: must be "glob" or "regex" (default "glob")
            if "type" in rule:
                if rule["type"] not in ("glob", "regex"):
                    issues.append(
                        f"'{category}'[{i}].type must be 'glob' or 'regex', got {rule['type']!r}"
                    )
                elif rule["type"] == "regex" and isinstance(rule.get("pattern"), str):
                    # Try to compile the regex; report syntax errors at validate time
                    pat = rule["pattern"]
                    try:
                        import re as _re
                        _re.compile(pat)
                    except _re.error as e:
                        issues.append(
                            f"'{category}'[{i}].pattern is invalid regex: {e}"
                        )
                    # Regex rules use re.search (substring match). Warn
                    # for deny rules without ^ — 'az$' would match 'notaz'.
                    if category == "deny" and not pat.startswith(("^", "(?")) and "^" not in pat[:5]:
                        issues.append(
                            f"'{category}'[{i}].pattern={pat!r}: regex deny rules without "
                            "an explicit '^' anchor are substring-matched, weaker than likely intended. "
                            "Add '^' (or use type='glob' which has implicit anchoring)."
                        )
            # Warn about unknown keys (don't fail — schema is forward-compatible)
            known = {"pattern", "message", "claude_only", "type"}
            unknown = set(rule.keys()) - known
            if unknown:
                issues.append(f"'{category}'[{i}] unknown key(s): {sorted(unknown)} (will be ignored)")

    return issues


def _fetch_rule_message(tool: str, rule_pattern: str) -> str | None:
    """Look up the rule's `message` field in the merged config, if present."""
    if not rule_pattern or rule_pattern.startswith("<"):
        return None
    engine = _find_engine()
    if not engine:
        return None
    sys.path.insert(0, str(engine.parent))
    try:
        from tool_guard import _load_config  # type: ignore
    except ImportError:
        return None
    cfg = _load_config(tool)
    for category in ("deny", "warn", "allow"):
        for r in cfg.get(category, []):
            if r.get("pattern") == rule_pattern:
                return r.get("message")
    return None


INSTALL_HINTS = {
    "az":    "curl -sL https://aka.ms/InstallAzureCLIDeb | sudo bash",
    "gh":    "See https://github.com/cli/cli/blob/trunk/docs/install_linux.md  (or: sudo apt install gh)",
    "git":   "sudo apt install git",
    "sleep": "ships with coreutils — should be present (check that /usr/bin is in PATH)",
}


def _which_all(name: str) -> list[str]:
    """Return all PATH entries for `name` in order, like `which -a`.
    Returns absolute paths only (relative PATH entries like `.` are
    skipped — we'd otherwise bake a cwd-dependent path into the stub
    via _patch_real_bin, which breaks the moment cwd changes). Skips
    duplicates by resolved path. We don't use shutil.which() because
    it returns only the first match and we need to skip our own
    wrapper at INSTALL_DIR."""
    out = []
    seen = set()
    for d in os.environ.get("PATH", "").split(os.pathsep):
        if not d:
            continue
        d_path = Path(d)
        if not d_path.is_absolute():
            continue  # baking a relative path would break at runtime
        cand = d_path / name
        try:
            if cand.is_file() and os.access(cand, os.X_OK):
                rp = str(cand.resolve())
                if rp in seen:
                    continue
                seen.add(rp)
                out.append(str(cand))
        except OSError:
            continue
    return out


def _discover_real_binary(tool: str) -> str | None:
    """Find the real binary for `tool`, EXCLUDING our own wrapper at
    INSTALL_DIR/<tool>. Priority:
      1. INSTALL_DIR/<tool>-real (the canonical "I moved my custom build
         out of the way" location — `which` won't find it, suffixed name)
      2. which -a <tool>, skipping INSTALL_DIR/<tool>"""
    real_suffix = INSTALL_DIR / f"{tool}-real"
    if real_suffix.is_file() and os.access(real_suffix, os.X_OK):
        return str(real_suffix)
    our_path = INSTALL_DIR / tool
    for path in _which_all(tool):
        # Skip our own wrapper if it's already installed (post-install
        # re-run shouldn't pick the wrapper as the real binary).
        if path == str(our_path):
            continue
        try:
            if our_path.exists() and Path(path).resolve() == our_path.resolve():
                continue
        except OSError:
            pass
        return path
    return None


def _is_our_wrapper(path: Path) -> bool:
    """True if `path` is one of our tool-guard stubs."""
    try:
        with path.open("rb") as f:
            head = f.read(2048)
    except OSError:
        return False
    return _file_is_our_stub(head)


def _patch_real_bin(stub: Path, tool: str, real: str) -> tuple[bool, str]:
    """Replace the REAL_BIN default in `stub` with `real`. Locates the
    assignment by REAL_BIN_MARKER comment (avoids fragile Python-syntax
    matching). Idempotent."""
    default_path = f"/usr/bin/{tool}"
    if real == default_path:
        return (False, f"default real_bin {default_path} matches — no patch needed")
    # Reject path chars that would break embedding into a Python string
    # literal — " is legal in Linux file names but would corrupt the stub.
    if any(c in real for c in ('"', "\\", "\n", "\r")):
        return (False, f"refusing to patch with real_bin path containing unsafe chars: {real!r}")
    upper = tool.upper().replace("-", "_")
    try:
        text = stub.read_text(encoding="utf-8")
    except OSError as e:
        return (False, f"could not read {stub}: {e}")
    # Preserve the variable name on the original line — different stubs
    # use different names (REAL, REAL_SLEEP, …). Match `<NAME> = os.environ.get(...)`
    # via regex and rewrite only the default value.
    var_name_re = re.compile(
        r'^(\s*)(\w+)\s*=\s*os\.environ\.get\(\s*"' + re.escape(upper) +
        r'_TG_REAL_BIN"\s*,\s*"[^"]*"\s*\)\s*'
    )
    new_lines = []
    patched = False
    for line in text.splitlines(keepends=True):
        if REAL_BIN_MARKER in line and f"{upper}_TG_REAL_BIN" in line:
            m = var_name_re.match(line)
            if not m:
                # Marker present but line shape doesn't match — log + skip
                # rather than corrupt the stub.
                return (False, f"{REAL_BIN_MARKER} present in {stub} but assignment shape unexpected — proceeding without patch")
            indent, var_name = m.group(1), m.group(2)
            newline = "\n" if line.endswith("\n") else ""
            new_lines.append(
                f'{indent}{var_name} = os.environ.get("{upper}_TG_REAL_BIN", "{real}")  '
                f'{REAL_BIN_MARKER}{newline}'
            )
            patched = True
        else:
            new_lines.append(line)
    if not patched:
        return (False, f"could not find {REAL_BIN_MARKER} marker in {stub} — proceeding without patch")
    try:
        stub.write_text("".join(new_lines), encoding="utf-8")
    except OSError as e:
        return (False, f"could not write {stub} (read-only?): {e}")
    return (True, f"patched stub default: {default_path} → {real}")


def cmd_install(args) -> int:
    """Pre-flight discover + REAL_BIN patch + delegate to install.sh.

    For each requested (or auto-discovered) tool guard:
      1. Refuse if INSTALL_DIR/<name> exists and is NOT our wrapper
         (would shadow the user's real binary). Suggest mv-to-<name>-real.
      2. Find the real binary via `which -a` (or <name>-real fallback);
         skip with an install hint if not on PATH.
      3. Sed-patch the stub's REAL_BIN default to the discovered path.
      4. Hand the surviving names to install.sh for the actual sudo install.

    The pre-flight + patch logic used to live in tool-guard-install.sh —
    moving it here lets the bootstrap script be ~30 lines (clone + exec
    tg install) and keeps install logic where it can be unit-tested."""
    if _is_installed_mode():
        print(_red("tg install: already running from /usr/local/bin (installed mode); "
                   "run from a source clone (e.g. ~/.local/share/tool-guard-source/) to install."),
              file=sys.stderr)
        return 1

    script = PKG_ROOT / "install.sh"
    if not script.is_file():
        print(_red(f"tg install: install.sh not found at {script}"), file=sys.stderr)
        return 1

    # Targets: explicit names, or all discoverable tool guards in source tree.
    targets = list(args.names) if args.names else _discover_guards()
    if not targets:
        print(_red(f"tg install: no tool-guards found under {PKG_ROOT}/*/wrapper.py"),
              file=sys.stderr)
        return 1

    print(_bold(f"Pre-flight discovery for: {' '.join(targets)}"))
    print()

    survivors: list[str] = []
    skipped: list[str] = []

    for name in targets:
        stub = PKG_ROOT / name / "wrapper.py"
        if not stub.is_file():
            print(_yellow(f"⚠  {name}: not in package (no {stub}) — skipping"), file=sys.stderr)
            skipped.append(f"{name} (unknown)")
            continue

        # Reject if INSTALL_DIR/<name> is some non-wrapper binary (would shadow it)
        installed_path = INSTALL_DIR / name
        if installed_path.exists() and not _is_our_wrapper(installed_path):
            print(_yellow(f"⚠  {name}: {installed_path} exists and is NOT our wrapper "
                          f"(looks like a real binary)."), file=sys.stderr)
            print(f"     Installing here would shadow it. Move it aside first:")
            real_suffix_path = INSTALL_DIR / f"{name}-real"
            if real_suffix_path.exists():
                # `<name>-real` already exists — don't suggest `mv`
                # blindly (would silently clobber whatever's there).
                print(_yellow(f"     ⚠ {real_suffix_path} ALREADY EXISTS — inspect it first:"))
                print(f"         file {real_suffix_path}")
                print(f"         head -1 {real_suffix_path}")
                print(f"       Then either rename the existing -real out of the way OR")
                print(f"       set {name.upper().replace('-', '_')}_TG_REAL_BIN to a different path.")
            else:
                print(f"       sudo mv {installed_path} {installed_path}-real")
                print(f"     Then re-run — REAL_BIN default will be patched to point at it.")
            skipped.append(name)
            continue

        # Find the real binary; skip with install hint if missing
        real = _discover_real_binary(name)
        if not real:
            hint = INSTALL_HINTS.get(name, "(no install hint registered — install it manually)")
            print(_yellow(f"⚠  {name}: not installed on this system."), file=sys.stderr)
            print(f"     To install: {hint}")
            skipped.append(name)
            continue

        print(_green(f"✅ {name}: real binary found at {real}"))

        # Patch the stub's REAL_BIN default
        patched, msg = _patch_real_bin(stub, name, real)
        print(f"   {msg}")

        survivors.append(name)

    print()
    if not survivors:
        print(_red("tg install: nothing to install (all skipped). See messages above."),
              file=sys.stderr)
        return 1
    if skipped:
        print(_yellow(f"⚠  Skipping: {', '.join(skipped)}"), file=sys.stderr)
        print()

    print(_bold(f"Delegating install of: {' '.join(survivors)}"))
    print()
    return subprocess.run(["bash", str(script), *survivors]).returncode


